{
  "schema": "e2e_judgement.v1",
  "type": "object",
  "required": [
    "schema",
    "judge_role",
    "rubric_version",
    "dimension_scores",
    "overall_assessment",
    "confidence"
  ],
  "properties": {
    "schema": {"const": "e2e_judgement.v1"},
    "judge_role": {"enum": ["content", "visual"]},
    "rubric_version": {"type": "string"},
    "dimension_scores": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "dimension_id",
          "score",
          "rationale",
          "evidence",
          "issues",
          "recommendations"
        ],
        "properties": {
          "dimension_id": {
            "enum": [
              "information_density",
              "storyline",
              "expression",
              "information_presentation"
            ]
          },
          "score": {"type": "number"},
          "rationale": {"type": "string"},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["location", "observation"],
              "properties": {
                "location": {"type": "string"},
                "observation": {"type": "string"}
              }
            }
          },
          "issues": {"type": "array", "items": {"type": "string"}},
          "recommendations": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "overall_assessment": {"type": "string"},
    "confidence": {"enum": ["high", "medium", "low"]},
    "inspected_visuals": {"type": "array", "items": {"type": "string"}}
  }
}
