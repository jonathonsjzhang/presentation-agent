{
  "schema": "storyline.v3",
  "description": "Storyline Worker 的文档优先契约：Executive Summary、动态信息金字塔、章节级论证序列；禁止 pages。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "report_type",
    "executive_summary",
    "message_pyramid",
    "narrative_sequence",
    "report_outline",
    "appendix_plan",
    "alignment_audit",
    "upstream_revision_requests",
    "open_questions"
  ],
  "properties": {
    "agent_id": { "const": "storyline" },
    "schema": { "const": "storyline.v3" },
    "topic": { "type": "string", "minLength": 1 },
    "audience": {
      "type": "string",
      "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"]
    },
    "report_type": {
      "type": "string",
      "enum": ["deep_dive", "business_progress", "quick_sync"]
    },
    "executive_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["context", "core_answer", "key_findings", "implications", "expected_action"],
      "properties": {
        "context": { "type": "string", "minLength": 1 },
        "core_answer": { "type": "string", "minLength": 1 },
        "key_findings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statement", "finding_refs"],
            "properties": {
              "statement": { "type": "string", "minLength": 1 },
              "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "implications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["statement", "finding_refs"],
            "properties": {
              "statement": { "type": "string", "minLength": 1 },
              "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
            }
          }
        },
        "expected_action": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "finding_refs"],
          "properties": {
            "statement": { "type": "string", "minLength": 1 },
            "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        }
      }
    },
    "message_pyramid": {
      "type": "object",
      "additionalProperties": false,
      "required": ["governing_question", "apex", "supporting_messages"],
      "properties": {
        "governing_question": { "type": "string", "minLength": 1 },
        "apex": {
          "type": "object",
          "additionalProperties": false,
          "required": ["statement", "finding_refs"],
          "properties": {
            "statement": { "type": "string", "minLength": 1 },
            "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
          }
        },
        "supporting_messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "message_id",
              "statement",
              "relationship_to_apex",
              "finding_refs",
              "evidence_refs"
            ],
            "properties": {
              "message_id": { "type": "string", "minLength": 1 },
              "statement": { "type": "string", "minLength": 1 },
              "relationship_to_apex": { "type": "string", "minLength": 1 },
              "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "evidence_refs": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "narrative_sequence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "purpose", "depends_on", "transition"],
        "properties": {
          "section_id": { "type": "string" },
          "purpose": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "transition": { "type": "string" }
        }
      }
    },
    "report_outline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section_id",
              "heading",
              "section_question",
              "section_thesis",
              "content_units",
              "finding_refs",
              "evidence_refs",
              "counterarguments",
              "caveats",
              "transition_from",
              "transition_to"
            ],
            "properties": {
              "section_id": { "type": "string", "minLength": 1 },
              "heading": { "type": "string", "minLength": 1 },
              "section_question": { "type": "string", "minLength": 1 },
              "section_thesis": { "type": "string", "minLength": 1 },
              "content_units": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "content_unit_id",
                    "purpose",
                    "statement",
                    "finding_refs",
                    "evidence_refs",
                    "caveats"
                  ],
                  "properties": {
                    "content_unit_id": { "type": "string", "minLength": 1 },
                    "purpose": {
                      "type": "string",
                      "enum": ["claim", "evidence", "interpretation", "counterargument", "caveat", "decision"]
                    },
                    "statement": { "type": "string", "minLength": 1 },
                    "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } }
                    ,
                    "evidence_refs": { "type": "array", "items": { "type": "string" } },
                    "caveats": { "type": "array", "items": { "type": "string" } }
                  }
                }
              },
              "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
              "evidence_refs": { "type": "array", "items": { "type": "string" } },
              "counterarguments": { "type": "array", "items": { "type": "string" } },
              "caveats": { "type": "array", "items": { "type": "string" } },
              "transition_from": { "type": "string" },
              "transition_to": { "type": "string" }
            }
          }
        }
      }
    },
    "appendix_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["appendix_id", "title", "purpose", "source_refs"],
        "properties": {
          "appendix_id": { "type": "string" },
          "title": { "type": "string" },
          "purpose": { "type": "string" },
          "source_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "alignment_audit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executive_summary_matches_apex",
        "all_supporting_messages_traceable",
        "all_sections_traceable",
        "finding_coverage",
        "unsupported_claims",
        "notes"
      ],
      "properties": {
        "executive_summary_matches_apex": { "type": "boolean" },
        "all_supporting_messages_traceable": { "type": "boolean" },
        "all_sections_traceable": { "type": "boolean" },
        "finding_coverage": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["finding_id", "disposition", "locations", "rationale"],
            "properties": {
              "finding_id": { "type": "string", "minLength": 1 },
              "disposition": {
                "type": "string",
                "enum": ["main_story", "appendix", "omitted"]
              },
              "locations": { "type": "array", "items": { "type": "string" } },
              "rationale": { "type": "string", "minLength": 1 }
            }
          }
        },
        "unsupported_claims": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "upstream_revision_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["request_type", "finding_refs", "reason", "blocking_level"],
        "properties": {
          "request_type": {
            "type": "string",
            "enum": ["unsupported_apex", "missing_evidence", "conflicting_findings", "unclear_decision"]
          },
          "finding_refs": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string" },
          "blocking_level": { "type": "string", "enum": ["advisory", "blocking"] }
        }
      }
    },
    "open_questions": { "type": "array", "items": { "type": "string" } }
  }
}
