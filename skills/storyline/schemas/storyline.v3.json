{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "storyline.v3",
  "title": "Storyline worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["core_answer", "sections"],
  "properties": {
    "core_answer": {"type": "string", "minLength": 1},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["heading", "brief", "finding_refs"],
        "properties": {
          "heading": {"type": "string", "minLength": 1},
          "brief": {"type": "string", "minLength": 1},
          "finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "appendix_finding_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "open_issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
