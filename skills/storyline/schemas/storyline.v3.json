{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "storyline.v3",
  "title": "Storyline worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["core_answer", "executive_summary", "sections", "visual_evidence_plan"],
  "properties": {
    "core_answer": {"type": "string", "minLength": 1},
    "executive_summary": {
      "type": "string",
      "minLength": 250,
      "maxLength": 350,
      "description": "A final-reader Markdown bullet-form Executive Summary written after the storyline, following the same logic and section order. Use one string with newline-separated top-level and optional second-level bullets."
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["chapter", "heading", "brief", "finding_refs", "evidence_refs"],
        "properties": {
          "chapter": {
            "type": "string",
            "minLength": 1,
            "description": "Internal short label for locating the section. It is not the reader-facing section title."
          },
          "heading": {
            "type": "string",
            "minLength": 1,
            "description": "The section leadline: a conclusion-led title that states the judgement established by this section."
          },
          "brief": {
            "type": "string",
            "minLength": 1,
            "description": "A compact but complete editorial blueprint: the decisive evidence, supported inference, necessary explanation or boundary, and how the section advances the core answer. It is not final report prose."
          },
          "finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true,
            "description": "Evidence IDs from Analysis that are actually used by this section."
          },
          "visual_evidence_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "visual_evidence_plan": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "purpose", "evidence_refs", "data_type", "required", "placement", "section_heading", "order"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "data_asset_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "data_type": {"type": "string", "enum": ["time_series", "comparison", "distribution", "relationship", "process", "qualitative"]},
          "required": {"type": "boolean"},
          "placement": {"type": "string", "enum": ["opening", "section"]},
          "section_heading": {"type": "string", "minLength": 1},
          "order": {"type": "integer", "minimum": 1}
        }
      }
    },
    "appendix_finding_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "open_issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
