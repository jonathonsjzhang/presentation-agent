{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "storyline.v3",
  "title": "Storyline worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["core_answer", "sections"],
  "properties": {
    "core_answer": {"type": "string", "minLength": 1},
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["chapter", "heading", "brief", "finding_refs"],
        "properties": {
          "chapter": {
            "type": "string",
            "minLength": 1,
            "description": "Concise chapter/section name used to identify the topic, not the conclusion."
          },
          "heading": {
            "type": "string",
            "minLength": 1,
            "description": "The section leadline: a conclusion-led title that states the judgement established by this section."
          },
          "brief": {
            "type": "string",
            "minLength": 1,
            "description": "The core argument explaining how the section establishes its leadline."
          },
          "finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "appendix_finding_refs": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "open_issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
