{
  "rules": [
    {
      "id": "FMT-PPT-SL-G01",
      "applies_to": ["storyline_design"],
      "phase": ["generation", "review"],
      "level": "P0",
      "property": "unit_type",
      "instruction": "按页组织，pages[].unit_type 使用 page，并坚持一页一问一结论；高层正文默认 8-12 页且不得超过 15 页，无关细节进入附录。"
    },
    {
      "id": "FMT-PPT-AS-G01",
      "applies_to": ["argument_synthesis"],
      "phase": ["generation", "review"],
      "level": "P1",
      "property": "format_fit",
      "instruction": "论点必须能被压成结论标题和页级证明，不依赖长段文字才能成立。"
    },
    {
      "id": "FMT-PPT-PF-G01",
      "applies_to": ["page_filling"],
      "phase": ["generation", "review"],
      "level": "P0",
      "property": "unit_type",
      "instruction": "按 page 生成一页一结论的内容，优先用可验证图表表达关系，并控制正文密度与来源显示。"
    },
    {
      "id": "FMT-PPT-FM-G01",
      "applies_to": ["format"],
      "phase": ["generation", "review"],
      "level": "P0",
      "property": "format_contract",
      "instruction": "只生成 PPT slide：format=ppt，material_units[].unit_type=slide，render_plan 使用 mck_ppt_shape_native；每个正文页包含行动标题、主视觉或明确缺口、来源脚注，禁止加载 DOCX/HTML 执行流程。",
      "context_requirements": ["pages", "draft_material", "global_sources", "global_data_gaps"]
    },
    {
      "id": "FMT-PPT-FM-G02",
      "applies_to": ["format"],
      "phase": ["generation", "review"],
      "level": "P0",
      "property": "renderer_readiness",
      "instruction": "图表页提供可渲染 chart_spec；缺数据时改用安全版式并记录 open_design_tasks，不得伪造 completed render_result。"
    },
    {
      "id": "FMT-PPT-QA-G01",
      "applies_to": ["qa_preparation"],
      "phase": ["generation", "review"],
      "level": "P1",
      "property": "format_fit",
      "instruction": "按页面标题、关键图表和附录逐页扫描追问，并为高风险页准备 backup appendix。"
    },
    {
      "id": "FMT-PPT-SS-G01",
      "applies_to": ["speaker_script"],
      "phase": ["generation", "review"],
      "level": "P0",
      "property": "delivery_granularity",
      "instruction": "按页讲，先说标题判断，再讲主证据和 so-what，不逐条念 bullet。"
    }
  ]
}
