{
  "schema": "evidence_catalog.v1",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "source_units",
    "evidence_items",
    "source_unit_disposition",
    "unresolved_units",
    "coverage_summary"
  ],
  "properties": {
    "agent_id": {"const": "evidence_harvester"},
    "schema": {"const": "evidence_catalog.v1"},
    "source_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "source_unit_id",
          "source_id",
          "source_location",
          "modality",
          "raw_content",
          "inspection_status"
        ],
        "properties": {
          "source_unit_id": {"type": "string", "minLength": 1},
          "source_id": {"type": "string", "minLength": 1},
          "source_location": {"type": "string", "minLength": 1},
          "modality": {
            "type": "string",
            "enum": ["text", "table", "image"]
          },
          "raw_content": {"type": "string"},
          "inspection_status": {
            "type": "string",
            "enum": ["inspected", "unresolved"]
          },
          "attribution": {"type": "object"}
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "source_unit_refs",
          "type",
          "raw_content",
          "normalized_observation",
          "scope",
          "limitations"
        ],
        "properties": {
          "evidence_id": {"type": "string", "minLength": 1},
          "source_unit_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "type": {
            "type": "string",
            "enum": [
              "quantitative_data",
              "quote",
              "case",
              "caveat",
              "counterevidence",
              "explanatory_variable",
              "author_judgment",
              "definition_or_methodology"
            ]
          },
          "raw_content": {"type": "string"},
          "normalized_observation": {"type": "string"},
          "attribution": {"type": "object"},
          "scope": {
            "type": "string",
            "enum": [
              "individual_case",
              "sample",
              "population",
              "product",
              "market",
              "methodology",
              "unknown"
            ]
          },
          "limitations": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },
    "source_unit_disposition": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "evidence_refs", "reason"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["captured", "excluded", "unresolved"]
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "reason": {"type": "string"}
        }
      }
    },
    "unresolved_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_unit_id", "reason"],
        "properties": {
          "source_unit_id": {"type": "string"},
          "reason": {"type": "string"}
        }
      }
    },
    "coverage_summary": {
      "type": "object",
      "required": [
        "total_source_units",
        "captured_units",
        "excluded_units",
        "unresolved_units",
        "complete"
      ],
      "properties": {
        "total_source_units": {"type": "integer", "minimum": 0},
        "captured_units": {"type": "integer", "minimum": 0},
        "excluded_units": {"type": "integer", "minimum": 0},
        "unresolved_units": {"type": "integer", "minimum": 0},
        "complete": {"type": "boolean"}
      }
    }
  }
}
