{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "markdown_artifact.v1",
  "title": "Runtime receipt for a canonical Markdown artifact",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "agent_id", "artifact_kind", "content_path", "content_sha256"],
  "properties": {
    "schema": {"const": "markdown_artifact.v1"},
    "agent_id": {"type": "string", "minLength": 1},
    "artifact_kind": {"type": "string", "minLength": 1},
    "content_path": {"type": "string", "minLength": 1},
    "content_sha256": {"type": "string", "minLength": 16}
  }
}
