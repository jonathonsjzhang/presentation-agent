{
  "schema": "analysis.v1",
  "description": "Analysis Worker 的判断契约：只表达材料发现、解释、备选观点与不确定性，不生成最终 Executive Summary 或报告结构。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema",
    "topic",
    "analysis_questions",
    "material_readiness",
    "evidence_catalog_ref",
    "evidence_execution",
    "findings",
    "viewpoint_candidates",
    "decision_tensions",
    "assumptions",
    "data_gaps",
    "discussion_points",
    "open_questions",
    "quality_checks"
  ],
  "properties": {
    "agent_id": { "const": "analysis" },
    "schema": { "const": "analysis.v1" },
    "topic": { "type": "string", "minLength": 1 },
    "analysis_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "material_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_materials_present",
        "existing_evidence_catalog_present",
        "status",
        "material_types",
        "issues"
      ],
      "properties": {
        "raw_materials_present": { "type": "boolean" },
        "existing_evidence_catalog_present": { "type": "boolean" },
        "status": { "type": "string", "enum": ["ready", "limited", "blocked"] },
        "material_types": { "type": "array", "items": { "type": "string" } },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "evidence_catalog_ref": { "type": ["string", "null"] },
    "evidence_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "invoked",
        "invocation_reason",
        "coverage_summary",
        "unresolved_units",
        "blocking_impact"
      ],
      "properties": {
        "invoked": { "type": "boolean" },
        "invocation_reason": {
          "type": "string",
          "enum": [
            "reused_existing_catalog",
            "raw_materials_without_catalog",
            "no_raw_materials"
          ]
        },
        "coverage_summary": {
          "type": "object",
          "required": [
            "total_source_units",
            "captured_units",
            "excluded_units",
            "unresolved_units",
            "complete"
          ],
          "properties": {
            "total_source_units": { "type": "integer" },
            "captured_units": { "type": "integer" },
            "excluded_units": { "type": "integer" },
            "unresolved_units": { "type": "integer" },
            "complete": { "type": "boolean" }
          }
        },
        "unresolved_units": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source_unit_id", "reason", "impact"],
            "properties": {
              "source_unit_id": { "type": "string" },
              "reason": { "type": "string" },
              "impact": { "type": "string" }
            }
          }
        },
        "blocking_impact": { "type": "string", "enum": ["none", "limited", "blocking"] }
      }
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "finding_id",
          "statement",
          "finding_type",
          "supporting_evidence",
          "counter_evidence",
          "alternative_explanations",
          "confidence",
          "so_what",
          "decision_relevance"
        ],
        "properties": {
          "finding_id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "finding_type": {
            "type": "string",
            "enum": ["fact", "pattern", "comparison", "mechanism", "implication", "hypothesis"]
          },
          "supporting_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["evidence_ref", "source_unit_ref", "supports"],
              "properties": {
                "evidence_ref": { "type": "string" },
                "source_unit_ref": { "type": "string" },
                "supports": { "type": "string" }
              }
            }
          },
          "counter_evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["evidence_ref", "challenge"],
              "properties": {
                "evidence_ref": { "type": "string" },
                "challenge": { "type": "string" }
              }
            }
          },
          "alternative_explanations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["explanation", "status"],
              "properties": {
                "explanation": { "type": "string" },
                "status": { "type": "string", "enum": ["supported", "plausible", "weak", "rejected"] },
                "evidence_refs": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "confidence": { "type": "string", "enum": ["high", "medium", "low"] },
          "so_what": { "type": "string", "minLength": 1 },
          "decision_relevance": { "type": "string", "minLength": 1 }
        }
      }
    },
    "viewpoint_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["viewpoint_id", "statement", "finding_refs", "strength", "tradeoffs"],
        "properties": {
          "viewpoint_id": { "type": "string" },
          "statement": { "type": "string" },
          "finding_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "strength": { "type": "string", "enum": ["recommended", "credible", "exploratory"] },
          "tradeoffs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "decision_tensions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tension", "option_a", "option_b", "decision_needed"],
        "properties": {
          "tension": { "type": "string" },
          "option_a": { "type": "string" },
          "option_b": { "type": "string" },
          "decision_needed": { "type": "string" }
        }
      }
    },
    "assumptions": { "type": "array", "items": { "type": "string" } },
    "data_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gap", "impact", "needed_input", "blocking_level"],
        "properties": {
          "gap": { "type": "string" },
          "impact": { "type": "string" },
          "needed_input": { "type": "string" },
          "blocking_level": { "type": "string", "enum": ["advisory", "blocking"] }
        }
      }
    },
    "discussion_points": { "type": "array", "items": { "type": "string" } },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "quality_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "status", "notes"],
        "properties": {
          "check": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warning", "fail"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
