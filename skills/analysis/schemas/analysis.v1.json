{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "analysis.v1",
  "title": "Analysis worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["findings", "thesis_options", "visual_evidence_candidates"],
  "properties": {
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "claim", "evidence_refs", "confidence", "so_what"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "so_what": {"type": "string", "minLength": 1},
          "challenges": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "thesis_options": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["option_id", "main_thesis", "sub_theses"],
        "properties": {
          "option_id": {"type": "string", "minLength": 1},
          "main_thesis": {"type": "string", "minLength": 1},
          "sub_theses": {
            "type": "array",
            "minItems": 2,
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": true,
              "required": ["claim", "finding_refs", "confidence"],
              "properties": {
                "claim": {"type": "string", "minLength": 1},
                "finding_refs": {
                  "type": "array",
                  "items": {"type": "string", "minLength": 1},
                  "uniqueItems": true
                },
                "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
                "why_it_matters": {"type": "string"}
              }
            }
          },
          "best_for": {"type": "string"},
          "evidence_strength": {"type": "string"},
          "tradeoffs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "visual_evidence_candidates": {
      "type": "array",
      "description": "Core claims whose evidence should be shown visually downstream. Empty is allowed only when no finding benefits from comparison, trend, distribution, relationship, process, or structured qualitative display.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "purpose", "finding_refs", "evidence_refs", "data_type", "required"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "finding_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "data_asset_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "data_type": {
            "type": "string",
            "enum": ["time_series", "comparison", "distribution", "relationship", "process", "qualitative"]
          },
          "required": {"type": "boolean"},
          "missing_data": {"type": "string"}
        }
      }
    },
    "open_issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
