{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "analysis.v1",
  "title": "Analysis worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["findings"],
  "properties": {
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "claim", "evidence_refs", "confidence", "so_what"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "so_what": {"type": "string", "minLength": 1},
          "challenges": {
            "type": "array",
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          }
        }
      }
    },
    "open_issues": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    }
  }
}
