{
  "schema": "speaker_script.v1",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "format",
    "target_duration_minutes",
    "delivery_strategy",
    "opening",
    "time_plan",
    "page_scripts",
    "compressed_version",
    "one_minute_version",
    "transition_lines",
    "risk_lines",
    "qa_bridge_lines",
    "unresolved_input_needed",
    "rehearsal_notes",
    "closing"
  ],
  "properties": {
    "agent_id": { "const": "speaker_script" },
    "schema": { "const": "speaker_script.v1" },
    "topic": { "type": "string" },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "format": { "type": "string", "enum": ["document", "ppt", "html"] },
    "target_duration_minutes": { "type": "number" },
    "delivery_strategy": {
      "type": "object",
      "required": ["tone", "detail_level", "format_strategy", "risk_posture"],
      "properties": {
        "tone": { "type": "string" },
        "detail_level": { "type": "string" },
        "format_strategy": { "type": "string" },
        "risk_posture": { "type": "string" }
      }
    },
    "opening": {
      "type": "object",
      "required": ["spoken_script", "core_message", "audience_ask", "suggested_duration_seconds"],
      "properties": {
        "spoken_script": { "type": "string" },
        "context_hook": { "type": "string" },
        "core_message": { "type": "string" },
        "audience_ask": { "type": "string" },
        "suggested_duration_seconds": { "type": "integer" }
      }
    },
    "time_plan": {
      "type": "object",
      "required": ["target_duration_minutes", "total_estimated_minutes", "page_allocations", "over_time_risks"],
      "properties": {
        "target_duration_minutes": { "type": "number" },
        "total_estimated_minutes": { "type": "number" },
        "page_allocations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["unit_id", "duration_seconds", "priority"],
            "properties": {
              "unit_id": { "type": "string" },
              "duration_seconds": { "type": "integer" },
              "priority": { "type": "string" },
              "compression_instruction": { "type": "string" },
              "optional_skip": { "type": "boolean" }
            }
          }
        },
        "over_time_risks": { "type": "array" }
      }
    },
    "page_scripts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "source_unit_id",
          "source_page_no",
          "headline",
          "key_message",
          "spoken_script",
          "evidence_to_say",
          "what_to_skip",
          "transition_to_next",
          "suggested_duration_seconds",
          "risk_bridge_lines",
          "qa_preemptions",
          "timing_status"
        ],
        "properties": {
          "unit_id": { "type": "string" },
          "source_unit_id": { "type": "string" },
          "source_page_no": { "type": "integer" },
          "headline": { "type": "string" },
          "key_message": { "type": "string" },
          "spoken_script": { "type": "string" },
          "evidence_to_say": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "evidence_ref": { "type": "string" },
                "talking_point": { "type": "string" },
                "caveat": { "type": "string" }
              }
            }
          },
          "what_to_skip": { "type": "array", "items": { "type": "string" } },
          "transition_to_next": { "type": "string" },
          "suggested_duration_seconds": { "type": "integer" },
          "risk_bridge_lines": { "type": "array", "items": { "type": "string" } },
          "qa_preemptions": { "type": "array", "items": { "type": "string" } },
          "pause_cues": { "type": "array", "items": { "type": "string" } },
          "emphasis_cues": { "type": "array", "items": { "type": "string" } },
          "timing_status": { "type": "string" }
        }
      }
    },
    "compressed_version": {
      "type": "object",
      "required": ["target_duration_minutes", "spoken_script", "units_to_cover", "units_to_skip"],
      "properties": {
        "target_duration_minutes": { "type": "number" },
        "spoken_script": { "type": "string" },
        "units_to_cover": { "type": "array", "items": { "type": "string" } },
        "units_to_skip": { "type": "array", "items": { "type": "string" } }
      }
    },
    "one_minute_version": {
      "type": "object",
      "required": ["spoken_script", "core_message", "next_step"],
      "properties": {
        "spoken_script": { "type": "string" },
        "core_message": { "type": "string" },
        "next_step": { "type": "string" }
      }
    },
    "transition_lines": { "type": "array", "items": { "type": "string" } },
    "risk_lines": { "type": "array", "items": { "type": "string" } },
    "qa_bridge_lines": { "type": "array", "items": { "type": "string" } },
    "unresolved_input_needed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["input_needed", "why_it_matters", "fallback_line"],
        "properties": {
          "input_needed": { "type": "string" },
          "related_question_id": { "type": "string" },
          "why_it_matters": { "type": "string" },
          "fallback_line": { "type": "string" }
        }
      }
    },
    "rehearsal_notes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["note_type", "note"],
        "properties": {
          "note_type": { "type": "string" },
          "unit_id": { "type": "string" },
          "note": { "type": "string" },
          "action": { "type": "string" }
        }
      }
    },
    "closing": {
      "type": "object",
      "required": ["spoken_script", "recap", "decision_or_next_step", "suggested_duration_seconds"],
      "properties": {
        "spoken_script": { "type": "string" },
        "recap": { "type": "string" },
        "decision_or_next_step": { "type": "string" },
        "risk_boundary": { "type": "string" },
        "suggested_duration_seconds": { "type": "integer" }
      }
    }
  }
}
