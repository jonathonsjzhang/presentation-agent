{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "speaker_script.v1",
  "title": "Speaker script worker submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["script_markdown"],
  "properties": {
    "script_markdown": {"type": "string", "minLength": 200},
    "target_minutes": {"type": "number", "exclusiveMinimum": 0},
    "risk_bridges": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
