{
  "schema": "report.v1",
  "description": "Report Worker 的内容契约：可独立阅读的完整分析报告语义结构。追溯性由 narrative_blocks 内嵌的 claim_ids/evidence_refs 与 source_registry 保证，不单独维护全局 claim/finding 表。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema",
    "report_metadata",
    "executive_summary",
    "sections",
    "source_registry",
    "caveats_and_limits",
    "recommendations",
    "appendices",
    "format_handoff"
  ],
  "properties": {
    "agent_id": { "const": "report" },
    "schema": { "const": "report.v1" },
    "report_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "topic", "audience", "report_type"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "topic": { "type": "string", "minLength": 1 },
        "audience": {
          "type": "string",
          "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"]
        },
        "report_type": {
          "type": "string",
          "enum": ["deep_dive", "business_progress", "quick_sync"]
        }
      }
    },
    "executive_summary": {
      "type": "object",
      "required": ["context", "core_answer", "key_findings", "implications", "expected_action"],
      "properties": {
        "context": { "type": "string", "minLength": 1 },
        "core_answer": { "type": "string", "minLength": 1 },
        "key_findings": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "implications": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "expected_action": { "type": "string", "minLength": 1 }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "section_id",
          "heading",
          "section_thesis",
          "narrative_blocks",
          "section_conclusion",
          "transition",
          "finding_refs",
          "claim_ids"
        ],
        "properties": {
          "section_id": { "type": "string", "minLength": 1 },
          "heading": { "type": "string", "minLength": 1 },
          "section_thesis": { "type": "string", "minLength": 1 },
          "narrative_blocks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["block_id", "block_type", "content", "claim_ids", "evidence_refs"],
              "properties": {
                "block_id": { "type": "string", "minLength": 1 },
                "block_type": {
                  "type": "string",
                  "enum": [
                    "paragraph",
                    "bullet_group",
                    "quote",
                    "table",
                    "figure_placeholder",
                    "callout",
                    "method_note",
                    "caveat"
                  ]
                },
                "content": { "type": "string" },
                "items": { "type": "array", "items": { "type": "string" } },
                "table": {
                  "type": "object",
                  "required": ["columns", "rows"],
                  "properties": {
                    "columns": { "type": "array", "minItems": 1, "items": { "type": "string" } },
                    "rows": { "type": "array", "items": { "type": "array" } }
                  }
                },
                "figure_spec": {
                  "type": "object",
                  "required": ["figure_type", "data", "reader_takeaway"],
                  "properties": {
                    "figure_type": { "type": "string" },
                    "data": { "type": "object" },
                    "reader_takeaway": { "type": "string" }
                  }
                },
                "claim_ids": {
                  "type": "array",
                  "items": { "type": "string", "minLength": 1 },
                  "description": "正文主张应绑定 claim；方法、过渡与 caveat 等非主张 block 可为空"
                },
                "evidence_refs": { "type": "array", "items": { "type": "string" } }
              }
            }
          },
          "section_conclusion": { "type": "string", "minLength": 1 },
          "transition": { "type": "string" },
          "finding_refs": {
            "type": "array",
            "items": { "type": "string" },
            "description": "分析章节应绑定 finding；导言、方法与附录型章节可为空"
          },
          "claim_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "description": "本节正文 block 中 claim_ids 的去重并集，供 Format 做稳定映射"
          }
        }
      }
    },
    "source_registry": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "citation"],
        "properties": {
          "source_id": { "type": "string" },
          "citation": { "type": "string" },
          "locator": { "type": "string" }
        }
      }
    },
    "caveats_and_limits": {
      "type": "object",
      "required": ["approach", "limitations"],
      "properties": {
        "approach": { "type": "string" },
        "definitions": { "type": "array", "items": { "type": "string" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "data_gaps": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement", "rationale"],
        "properties": {
          "statement": { "type": "string" },
          "rationale": { "type": "string" },
          "conditions": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "appendices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["appendix_id", "title", "content_refs"],
        "properties": {
          "appendix_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "content_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "format_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protected_caveats", "visual_opportunities"],
      "properties": {
        "protected_caveats": { "type": "array", "items": { "type": "string" } },
        "visual_opportunities": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
