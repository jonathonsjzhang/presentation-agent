{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "report.v1",
  "title": "Report worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["report_markdown", "visual_evidence_placements"],
  "properties": {
    "report_markdown": {
      "type": "string",
      "minLength": 500,
      "description": "A complete Markdown report that can be read from beginning to end."
    },
    "visual_evidence_placements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "claim", "purpose", "evidence_refs", "data_type", "required", "placement", "section_heading", "marker"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "claim": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "evidence_refs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "data_asset_refs": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true},
          "data_type": {"type": "string", "enum": ["time_series", "comparison", "distribution", "relationship", "process", "qualitative"]},
          "required": {"type": "boolean"},
          "placement": {"type": "string", "enum": ["opening", "section"]},
          "section_heading": {"type": "string", "minLength": 1},
          "marker": {"type": "string", "pattern": "^\\[可视化论据：[A-Za-z0-9_-]+\\]$"}
        }
      }
    }
  }
}
