{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "report.v1",
  "title": "Report worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["report_markdown"],
  "properties": {
    "report_markdown": {
      "type": "string",
      "minLength": 500,
      "description": "A complete Markdown report that can be read from beginning to end."
    }
  }
}
