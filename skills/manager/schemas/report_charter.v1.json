{
  "schema": "report_charter.v1",
  "type": "object",
  "required": [
    "topic",
    "audience",
    "report_type",
    "output_format",
    "decision_goal",
    "expected_action",
    "scope",
    "out_of_scope",
    "constraints",
    "success_criteria",
    "recommendation_granularity",
    "unsupported_specificity_policy",
    "evidence_inventory_policy",
    "global_state_seed",
    "blocking_questions"
  ],
  "properties": {
    "topic": {"type": "string"},
    "audience": {"type": "string"},
    "report_type": {"type": "string", "enum": ["deep_dive", "business_progress", "quick_sync"]},
    "output_format": {"type": "string", "enum": ["document", "ppt", "html"]},
    "decision_goal": {"type": "string"},
    "expected_action": {"type": "string"},
    "scope": {"type": "array", "items": {"type": "string"}},
    "out_of_scope": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "success_criteria": {"type": "array", "items": {"type": "string"}},
    "recommendation_granularity": {
      "type": "string",
      "enum": ["strategic_direction", "strategic_choice", "execution_plan"]
    },
    "unsupported_specificity_policy": {
      "type": "string",
      "enum": ["forbid", "source_backed_only", "allow"]
    },
    "evidence_inventory_policy": {
      "type": "string",
      "enum": ["full_catalog_for_deep_dive", "full_catalog", "lightweight_prepass"]
    },
    "material_inventory": {"type": "array"},
    "global_state_seed": {"type": "object"},
    "blocking_questions": {"type": "array", "items": {"type": "string"}},
    "assumptions": {"type": "array", "items": {"type": "string"}}
  }
}
