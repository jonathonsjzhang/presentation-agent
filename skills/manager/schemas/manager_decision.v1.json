{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal manager decision",
  "type": "object",
  "additionalProperties": true,
  "required": ["action"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["dispatch", "revise", "ask_human", "complete", "blocked"]
    },
    "report_charter": {"type": "object"},
    "task_packet": {"type": "object"},
    "acceptance_report": {"type": "object"},
    "stage": {"type": "string", "enum": ["analysis", "storyline", "report", "qa_preparation", "format"]},
    "feedback": {"type": "string"},
    "questions_for_human": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "user_message": {"type": "string"}
  }
}
