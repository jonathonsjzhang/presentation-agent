{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Minimal worker task packet",
  "type": "object",
  "additionalProperties": true,
  "required": ["agent_id", "objective", "input_artifacts"],
  "properties": {
    "agent_id": {
      "type": "string",
      "enum": ["analysis", "storyline", "report", "format", "qa_preparation", "speaker_script"]
    },
    "objective": {"type": "string", "minLength": 1},
    "input_artifacts": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "uniqueItems": true
    },
    "revision_feedback": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
