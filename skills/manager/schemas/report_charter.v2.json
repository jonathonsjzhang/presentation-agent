{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "report_charter.v2",
  "title": "Minimal report charter",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "topic",
    "audience",
    "report_type",
    "decision_question",
    "expected_action",
    "scope",
    "material_inventory"
  ],
  "properties": {
    "topic": {"type": "string", "minLength": 1},
    "audience": {"type": "string", "minLength": 1},
    "report_type": {
      "type": "string",
      "enum": ["deep_dive", "business_progress", "quick_sync"]
    },
    "decision_question": {"type": "string", "minLength": 1},
    "expected_action": {"type": "string", "minLength": 1},
    "scope": {
      "type": "array",
      "items": {
        "anyOf": [
          {"type": "string", "minLength": 1},
          {"type": "object"}
        ]
      }
    },
    "material_inventory": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "constraints": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "assumptions": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  }
}
