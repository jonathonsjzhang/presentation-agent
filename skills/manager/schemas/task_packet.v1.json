{
  "schema": "task_packet.v1",
  "type": "object",
  "required": [
    "task_id",
    "agent_id",
    "objective",
    "input_artifacts",
    "context",
    "constraints",
    "deliverables",
    "acceptance_criteria",
    "dependencies",
    "memory_dimensions",
    "recommendation_granularity",
    "unsupported_specificity_policy",
    "evidence_inventory_policy"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "agent_id": {"type": "string"},
    "objective": {"type": "string"},
    "input_artifacts": {"type": "array", "items": {"type": "string"}},
    "context": {"type": "object"},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "deliverables": {"type": "object"},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "memory_dimensions": {"type": "array", "items": {"type": "string"}},
    "recommendation_granularity": {
      "type": "string",
      "enum": ["strategic_direction", "strategic_choice", "execution_plan"]
    },
    "unsupported_specificity_policy": {
      "type": "string",
      "enum": ["forbid", "source_backed_only", "allow"]
    },
    "evidence_inventory_policy": {
      "type": "string",
      "enum": ["full_catalog_for_deep_dive", "full_catalog", "lightweight_prepass"]
    },
    "report_profile": {
      "type": "object",
      "properties": {
        "audience": {"type": "string"},
        "report_type": {"type": "string"},
        "output_format": {"type": "string"}
      }
    },
    "capability_expectations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "revision_of": {"type": ["string", "null"]},
    "revision_feedback": {"type": "array", "items": {"type": "string"}}
  }
}
