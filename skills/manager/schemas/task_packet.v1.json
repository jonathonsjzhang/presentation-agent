{
  "schema": "task_packet.v1",
  "type": "object",
  "required": [
    "task_id",
    "agent_id",
    "objective",
    "input_artifacts",
    "context",
    "constraints",
    "deliverables",
    "acceptance_criteria",
    "dependencies",
    "memory_dimensions"
  ],
  "properties": {
    "task_id": {"type": "string"},
    "agent_id": {"type": "string"},
    "objective": {"type": "string"},
    "input_artifacts": {"type": "array", "items": {"type": "string"}},
    "context": {"type": "object"},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "deliverables": {"type": "object"},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "memory_dimensions": {"type": "array", "items": {"type": "string"}},
    "report_profile": {
      "type": "object",
      "properties": {
        "audience": {"type": "string"},
        "report_type": {"type": "string"},
        "output_format": {"type": "string"}
      }
    },
    "capability_expectations": {
      "type": "array",
      "items": {"type": "string"}
    },
    "revision_of": {"type": ["string", "null"]},
    "revision_feedback": {"type": "array", "items": {"type": "string"}}
  }
}
