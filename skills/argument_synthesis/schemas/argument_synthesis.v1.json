{
  "schema": "argument_synthesis.v1",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "topic",
    "executive_summary",
    "core_question",
    "core_thesis",
    "expected_action",
    "thesis_candidates",
    "selection_reason",
    "key_arguments",
    "evidence_bank",
    "evidence_disposition",
    "risks_and_counterarguments",
    "evidence_gaps",
    "argument_read_test"
  ],
  "properties": {
    "agent_id": {"const": "argument_synthesis"},
    "schema": {"const": "argument_synthesis.v1"},
    "topic": {"type": "string"},
    "context_summary": {"type": "string"},
    "executive_summary": {
      "type": "object",
      "required": [
        "core_conclusion",
        "decision_relevance",
        "urgency_basis",
        "decision_request",
        "supporting_arguments"
      ],
      "properties": {
        "core_conclusion": {"type": "string"},
        "decision_relevance": {"type": "string"},
        "urgency_basis": {
          "type": ["object", "null"],
          "properties": {
            "statement": {"type": "string"},
            "source_refs": {
              "type": "array",
              "minItems": 1,
              "items": {"type": "string"}
            }
          },
          "required": ["statement", "source_refs"]
        },
        "decision_request": {
          "type": "object",
          "required": [
            "decision_type",
            "recommended_direction",
            "rationale_claim_refs",
            "specificity_level",
            "source_backed_specifics"
          ],
          "properties": {
            "decision_type": {
              "type": "string",
              "enum": [
                "do_or_not",
                "priority",
                "focus",
                "positioning",
                "tradeoff",
                "discussion"
              ]
            },
            "recommended_direction": {"type": "string"},
            "rationale_claim_refs": {
              "type": "array",
              "items": {"type": "string"}
            },
            "specificity_level": {
              "type": "string",
              "enum": [
                "strategic_direction",
                "strategic_choice",
                "execution_plan"
              ]
            },
            "source_backed_specifics": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["statement", "source_refs"],
                "properties": {
                  "statement": {"type": "string"},
                  "source_refs": {
                    "type": "array",
                    "minItems": 1,
                    "items": {"type": "string"}
                  }
                }
              }
            }
          }
        },
        "supporting_arguments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "claim",
              "claim_type",
              "support_level",
              "evidence_refs",
              "so_what"
            ],
            "properties": {
              "id": {"type": "string"},
              "claim": {"type": "string"},
              "claim_type": {
                "type": "string",
                "enum": [
                  "descriptive",
                  "comparative",
                  "explanatory",
                  "causal",
                  "predictive",
                  "recommendation"
                ]
              },
              "support_level": {
                "type": "string",
                "enum": ["supported", "directional", "hypothesis"]
              },
              "evidence_refs": {
                "type": "array",
                "items": {"type": "string"}
              },
              "so_what": {"type": "string"}
            }
          }
        }
      }
    },
    "core_question": {"type": "string"},
    "core_thesis": {"type": "string"},
    "expected_action": {"type": "string"},
    "desired_direction_alignment": {
      "type": "object",
      "properties": {
        "desired_direction": {"type": "string"},
        "alignment": {"type": "string"},
        "tensions": {"type": "array", "items": {"type": "string"}}
      }
    },
    "thesis_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "thesis",
          "decision_value",
          "evidence_strength",
          "audience_fit",
          "pros",
          "cons_or_risks"
        ],
        "properties": {
          "thesis": {"type": "string"},
          "decision_value": {"type": "string"},
          "evidence_strength": {"type": "string"},
          "audience_fit": {"type": "string"},
          "story_potential": {"type": "string"},
          "pros": {"type": "array", "items": {"type": "string"}},
          "cons_or_risks": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "selection_reason": {"type": "string"},
    "key_arguments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "claim",
          "claim_type",
          "support_level",
          "logic_chain",
          "evidence_refs",
          "counterevidence_refs",
          "assumptions",
          "boundary_conditions",
          "so_what",
          "confidence"
        ],
        "properties": {
          "id": {"type": "string"},
          "claim": {"type": "string"},
          "claim_type": {
            "type": "string",
            "enum": [
              "descriptive",
              "comparative",
              "explanatory",
              "causal",
              "predictive",
              "recommendation"
            ]
          },
          "support_level": {
            "type": "string",
            "enum": ["supported", "directional", "hypothesis"]
          },
          "why_it_matters": {"type": "string"},
          "logic_chain": {
            "type": "object",
            "required": ["observations", "inference", "implication"],
            "properties": {
              "observations": {
                "type": "array",
                "items": {"type": "string"}
              },
              "inference": {"type": "string"},
              "implication": {"type": "string"}
            }
          },
          "evidence": {"type": "array", "items": {"type": "string"}},
          "evidence_refs": {"type": "array", "items": {"type": "string"}},
          "counterevidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "assumptions": {"type": "array", "items": {"type": "string"}},
          "counterarguments": {"type": "array", "items": {"type": "string"}},
          "boundary_conditions": {
            "type": "array",
            "items": {"type": "string"}
          },
          "so_what": {"type": "string"},
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    },
    "evidence_catalog_ref": {"type": ["string", "null"]},
    "evidence_bank": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "content",
          "type",
          "confidence",
          "source_unit_refs"
        ],
        "properties": {
          "id": {"type": "string"},
          "content": {"type": "string"},
          "type": {"type": "string"},
          "source": {"type": "string"},
          "source_unit_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"}
          },
          "needs_source": {"type": "boolean"},
          "timeframe": {"type": "string"},
          "metric_or_scope": {"type": "string"},
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
          "limitations": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "evidence_disposition": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["status", "role", "claim_refs", "reason"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["selected", "counterpoint", "appendix", "excluded"]
          },
          "role": {"type": "string"},
          "claim_refs": {"type": "array", "items": {"type": "string"}},
          "reason": {"type": "string"}
        }
      }
    },
    "assumptions": {"type": "array"},
    "risks_and_counterarguments": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "risk_or_counterargument": {"type": "string"},
          "attacks": {"type": "string"},
          "boundary_condition": {"type": "string"},
          "evidence_needed": {"type": "string"},
          "impact_on_thesis": {"type": "string"}
        }
      }
    },
    "argument_read_test": {
      "type": "object",
      "required": ["passes", "micro_argument", "notes"],
      "properties": {
        "passes": {"type": "boolean"},
        "micro_argument": {"type": "string"},
        "notes": {"type": "string"}
      }
    },
    "evidence_gaps": {
      "type": "array",
      "description": "Only missing evidence needed to prove a claim; never unused existing material."
    },
    "open_questions": {"type": "array"},
    "storyline_handoff": {
      "type": "object",
      "properties": {
        "executive_summary_to_use": {"type": "string"},
        "argument_order": {"type": "array", "items": {"type": "string"}},
        "evidence_refs_by_argument": {"type": "object"},
        "boundaries_not_to_overclaim": {
          "type": "array",
          "items": {"type": "string"}
        },
        "full_evidence_location": {"type": "string"}
      }
    },
    "recommended_story_angles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["angle", "best_for", "tradeoff", "required_evidence", "risk"],
        "properties": {
          "angle": {"type": "string"},
          "best_for": {"type": "string"},
          "tradeoff": {"type": "string"},
          "required_evidence": {"type": "array", "items": {"type": "string"}},
          "risk": {"type": "string"}
        }
      }
    }
  }
}
