{
  "schema": "formatted_material.v2",
  "description": "Format Worker 的单载体转译契约。输入必须来自 report.v1，并显式记录压缩、省略、caveat 保留和渲染结果。",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "delivery_target",
    "source_report_ref",
    "source_section_ids",
    "source_claim_ids",
    "delivery_units",
    "visual_assets",
    "compression_decisions",
    "omitted_content_register",
    "caveat_preservation",
    "artifact_manifest",
    "render_plan",
    "render_result",
    "quality_checks"
  ],
  "properties": {
    "agent_id": { "const": "format" },
    "schema": { "const": "formatted_material.v2" },
    "topic": { "type": "string", "minLength": 1 },
    "audience": {
      "type": "string",
      "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"]
    },
    "delivery_target": {
      "type": "string",
      "enum": ["document", "ppt", "html"],
      "description": "一个 Format task 只处理一个载体。"
    },
    "source_report_ref": { "type": "string", "minLength": 1 },
    "source_section_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "source_claim_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "delivery_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit_id",
          "unit_type",
          "headline",
          "content",
          "source_section_ids",
          "source_claim_ids",
          "source_evidence_refs",
          "caveats",
          "visual_asset_refs",
          "transformation"
        ],
        "properties": {
          "unit_id": { "type": "string", "minLength": 1 },
          "unit_type": {
            "type": "string",
            "enum": ["document_section", "slide", "html_module"]
          },
          "headline": { "type": "string", "minLength": 1 },
          "content": {
            "type": "object",
            "required": ["primary_text", "supporting_points", "tables"],
            "properties": {
              "primary_text": { "type": "string" },
              "supporting_points": { "type": "array", "items": { "type": "string" } },
              "tables": { "type": "array", "items": { "type": "object" } }
            }
          },
          "source_section_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_claim_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "source_evidence_refs": { "type": "array", "items": { "type": "string" } },
          "caveats": { "type": "array", "items": { "type": "string" } },
          "visual_asset_refs": { "type": "array", "items": { "type": "string" } },
          "transformation": {
            "type": "string",
            "enum": ["preserved", "reordered", "compressed", "split", "merged"]
          }
        }
      }
    },
    "visual_assets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "asset_id",
          "asset_type",
          "title",
          "reader_takeaway",
          "data",
          "source_section_ids",
          "source_claim_ids",
          "source_evidence_refs",
          "source_note",
          "caveats",
          "render_status"
        ],
        "properties": {
          "asset_id": { "type": "string", "minLength": 1 },
          "asset_type": {
            "type": "string",
            "enum": ["chart", "table", "diagram", "matrix", "process", "timeline", "callout", "image"]
          },
          "title": { "type": "string", "minLength": 1 },
          "reader_takeaway": { "type": "string", "minLength": 1 },
          "data": { "type": "object" },
          "source_section_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "source_claim_ids": { "type": "array", "items": { "type": "string" } },
          "source_evidence_refs": { "type": "array", "items": { "type": "string" } },
          "source_note": { "type": "string" },
          "caveats": { "type": "array", "items": { "type": "string" } },
          "render_status": {
            "type": "string",
            "enum": ["planned", "rendered", "skipped", "error"]
          }
        }
      }
    },
    "compression_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decision_id", "source_refs", "action", "rationale", "meaning_preserved"],
        "properties": {
          "decision_id": { "type": "string" },
          "source_refs": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "action": { "type": "string", "enum": ["compress", "merge", "split", "reorder"] },
          "rationale": { "type": "string" },
          "meaning_preserved": { "type": "boolean" }
        }
      }
    },
    "omitted_content_register": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_ref", "content_summary", "reason", "risk", "recoverable_location"],
        "properties": {
          "source_ref": { "type": "string" },
          "content_summary": { "type": "string" },
          "reason": { "type": "string" },
          "risk": { "type": "string", "enum": ["none", "low", "medium", "high"] },
          "recoverable_location": { "type": "string" }
        }
      }
    },
    "caveat_preservation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_caveat", "source_ref", "destination_unit_ids", "status"],
        "properties": {
          "source_caveat": { "type": "string" },
          "source_ref": { "type": "string" },
          "destination_unit_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["preserved", "reworded_equivalent", "missing"] }
        }
      }
    },
    "artifact_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target", "deliverables"],
      "properties": {
        "target": { "type": "string", "enum": ["document", "ppt", "html"] },
        "deliverables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["file_type", "intended_path", "status"],
            "properties": {
              "file_type": { "type": "string" },
              "intended_path": { "type": "string" },
              "status": { "type": "string", "enum": ["planned", "rendered", "error"] },
              "blocking_reason": { "type": "string" }
            }
          }
        }
      }
    },
    "render_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["renderer", "unit_order", "asset_order", "qa_steps"],
      "properties": {
        "renderer": { "type": "string", "minLength": 1 },
        "unit_order": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "asset_order": { "type": "array", "items": { "type": "string" } },
        "qa_steps": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "render_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "target", "output_path", "unit_count", "warnings"],
      "properties": {
        "status": { "type": "string", "enum": ["planned", "rendered", "error"] },
        "target": { "type": "string", "enum": ["document", "ppt", "html"] },
        "output_path": { "type": "string" },
        "unit_count": { "type": "integer" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "quality_checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["check", "status", "notes"],
        "properties": {
          "check": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "warning", "fail", "pending"] },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
