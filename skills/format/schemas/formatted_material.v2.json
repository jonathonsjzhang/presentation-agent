{
  "schema": "formatted_material.v2",
  "description": "v3 当前阶段正式材料契约。在 v1 基础上，material_unit.layout_or_structure.layout_type 强制收敛到 v3 的 5 类实证 layout，material_unit.presentation_style_ref 强制引用 format.ppt §X 章节。",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "format",
    "input_readiness",
    "artifact_manifest",
    "render_plan",
    "material_units",
    "style_tokens",
    "source_policy",
    "gap_policy",
    "redaction_policy",
    "format_decisions",
    "downstream_handoff",
    "quality_checks"
  ],
  "properties": {
    "agent_id": { "const": "format" },
    "schema": { "const": "formatted_material.v2" },
    "topic": { "type": "string" },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "format": { "type": "string", "enum": ["ppt", "document", "html"], "const": "ppt" },
    "input_readiness": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["ready", "partial", "blocked"] }
      }
    },
    "artifact_manifest": { "type": "object" },
    "render_plan": {
      "type": "object",
      "required": ["renderer"],
      "properties": {
        "renderer": {
          "type": "string",
          "enum": ["python-pptx", "mck-engine", "docx", "html-static"],
          "description": "v3 默认 python-pptx（实证高质量）；mck-engine 仍在 v3 旧版的实验状态。"
        }
      }
    },
    "material_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "source_page_no",
          "unit_type",
          "headline",
          "layout_or_structure",
          "finalized_content",
          "visual_object",
          "source_display",
          "gap_display",
          "quality_status"
        ],
        "properties": {
          "unit_id": { "type": "string" },
          "source_page_no": { "type": "integer" },
          "unit_type": {
            "type": "string",
            "enum": [
              "cover",
              "executive_summary",
              "analysis_dashboard",
              "methodology_or_strategy",
              "priority_matrix"
            ],
            "description": "[v3 强制] 只允许 v3 实证过的 5 类 layout_type。"
          },
          "headline": { "type": "string" },
          "layout_or_structure": {
            "type": "object",
            "required": ["layout_type", "presentation_style_ref"],
            "properties": {
              "layout_type": {
                "type": "string",
                "enum": ["cover", "executive_summary", "analysis_dashboard", "methodology_or_strategy", "priority_matrix"]
              },
              "presentation_style_ref": {
                "type": "string",
                "pattern": "^format\\.ppt §[A-Za-z0-9-]+\\.[A-Za-z0-9-]+$",
                "description": "必填，引用 format.ppt 的具体章节（如 'format.ppt §layout.cover'）。"
              }
            }
          },
          "finalized_content": {
            "type": "object",
            "required": ["primary_text"],
            "properties": {
              "primary_text": { "type": "string" },
              "supporting_points": { "type": "array" },
              "callouts": { "type": "array" },
              "quote_blocks": { "type": "array" }
            }
          },
          "visual_object": {
            "type": "object",
            "properties": {
              "chart_type": {
                "type": "string",
                "enum": ["bar_chart", "grouped_bar", "horizontal_bar", "scatter", "matrix_table", "quoted_table"]
              },
              "chart_spec": { "type": "object" },
              "table_data": { "type": "array" },
              "shape_spec": { "type": "array" },
              "data_source_extraction": {
                "type": "string",
                "description": "[v3 强制] 记录数据提取位置（如 'doc.pdf §3.2 Table 2'），禁止模拟数据。"
              }
            }
          },
          "source_display": { "type": "object" },
          "gap_display": { "type": "object" },
          "quality_status": {
            "type": "string",
            "enum": ["complete", "partial", "blocked"]
          }
        }
      }
    },
    "style_tokens": {
      "type": "object",
      "description": "v3 量化值取自 references/style.md（v0.9.1 实证）。",
      "properties": {
        "typography": { "type": "object" },
        "color": { "type": "object" },
        "spacing": { "type": "object" }
      }
    },
    "source_policy": { "type": "object" },
    "gap_policy": { "type": "object" },
    "redaction_policy": { "type": "object" },
    "format_decisions": { "type": "array" },
    "open_design_tasks": { "type": "array" },
    "downstream_handoff": { "type": "object" },
    "quality_checks": { "type": "array" }
  }
}
