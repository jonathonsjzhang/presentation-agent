{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema": "formatted_material.v2",
  "title": "Format worker submission",
  "type": "object",
  "additionalProperties": true,
  "required": ["visuals"],
  "properties": {
    "visuals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_heading", "type", "title", "source_refs"],
        "properties": {
          "section_heading": {"type": "string", "minLength": 1},
          "type": {"type": "string", "enum": ["chart", "table", "matrix", "callout"]},
          "title": {"type": "string", "minLength": 1},
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1},
            "uniqueItems": true
          },
          "data": {"type": "object"}
        }
      }
    }
  }
}
