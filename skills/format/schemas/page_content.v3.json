{
  "schema": "page_content.v3",
  "description": "v3 当前阶段 page_content 契约。在 v2 基础上，对 format_handoff_notes 增加 v3 5 类实证 layout_type 的提示，强制 format worker 收敛到这些 layout。",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "report_type",
    "output_format",
    "pages",
    "global_sources",
    "global_data_gaps",
    "format_handoff_summary"
  ],
  "properties": {
    "agent_id": { "const": "page_filling" },
    "schema": { "const": "page_content.v3" },
    "topic": { "type": "string" },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "report_type": { "type": "string", "enum": ["deep_dive", "business_progress", "quick_sync"] },
    "output_format": { "type": "string", "enum": ["document", "ppt", "html"] },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "page_no",
          "title",
          "key_question",
          "page_takeaway",
          "proof_chain",
          "content_blocks",
          "visual_plan",
          "sources",
          "data_gaps",
          "format_handoff_notes"
        ],
        "properties": {
          "page_no": { "type": "integer" },
          "title": { "type": "string" },
          "key_question": { "type": "string" },
          "page_takeaway": { "type": "string" },
          "claim_strength": {
            "type": "string",
            "enum": ["fact", "finding", "implication", "recommendation", "hypothesis"]
          },
          "proof_chain": { "type": "array" },
          "content_blocks": { "type": "array" },
          "visual_plan": { "type": "object" },
          "sources": { "type": "array" },
          "data_gaps": { "type": "array" },
          "format_handoff_notes": {
            "type": "object",
            "description": "[v3 增强] format worker 必读字段。包含 layout_type 推荐 / 组件必填项 / 字号建议。",
            "properties": {
              "recommended_layout_type": {
                "type": "string",
                "enum": ["cover", "executive_summary", "analysis_dashboard", "methodology_or_strategy", "priority_matrix"],
                "description": "v3 的 5 类实证 layout。format worker 不得使用本表外的 layout_type。"
              },
              "required_components": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["navigation", "insight_panel", "pp_callout", "warning_frame", "numbered_marker", "quote_box", "footer", "title_block", "card"]
                }
              },
              "data_audit_required": {
                "type": "boolean",
                "description": "若 true，format worker 必须保留 data_source_extraction 字段，禁止模拟数据。"
              }
            }
          }
        }
      }
    },
    "global_sources": { "type": "array" },
    "global_data_gaps": { "type": "array" },
    "format_handoff_summary": { "type": "object" }
  }
}
