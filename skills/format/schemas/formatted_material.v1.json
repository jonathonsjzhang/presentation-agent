{
  "schema": "formatted_material.v1",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "format",
    "audience",
    "topic",
    "artifact_manifest",
    "render_plan",
    "material_units",
    "style_tokens",
    "source_policy",
    "gap_policy",
    "format_decisions",
    "open_design_tasks",
    "downstream_handoff",
    "quality_checks"
  ],
  "properties": {
    "agent_id": { "const": "format" },
    "schema": { "const": "formatted_material.v1" },
    "format": { "type": "string", "enum": ["document", "ppt", "html"] },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "topic": { "type": "string" },
    "artifact_manifest": {
      "type": "object",
      "required": ["target_format", "deliverables", "render_status"],
      "properties": {
        "target_format": { "type": "string", "enum": ["document", "ppt", "html"] },
        "deliverables": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file_type", "intended_path", "status"],
            "properties": {
              "file_type": { "type": "string" },
              "intended_path": { "type": "string" },
              "status": { "type": "string" },
              "blocking_reason": { "type": "string" }
            }
          }
        },
        "render_status": { "type": "string" },
        "blocking_gaps": { "type": "array" }
      }
    },
    "render_plan": {
      "type": "object",
      "properties": {
        "generation_path": { "type": "string" },
        "renderer": { "type": "string" },
        "unit_order": { "type": "array", "items": { "type": "string" } },
        "asset_requirements": { "type": "array" },
        "manual_steps": { "type": "array" }
      }
    },
    "material_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "unit_id",
          "source_page_no",
          "unit_type",
          "headline",
          "layout_or_structure",
          "finalized_content",
          "source_display",
          "gap_display",
          "quality_status"
        ],
        "properties": {
          "unit_id": { "type": "string" },
          "source_page_no": { "type": "integer" },
          "unit_type": { "type": "string", "enum": ["slide", "html_module", "document_section"] },
          "headline": { "type": "string" },
          "layout_or_structure": {
            "type": "object",
            "properties": {
              "layout_type": {
                "type": "string",
                "description": "渲染版式名，必须取自渲染引擎支持的枚举（McKinsey 版式库）。未知值会安全降级为文本版式。",
                "enum": [
                  "cover",
                  "section_divider",
                  "executive_summary",
                  "key_takeaway",
                  "four_column",
                  "scorecard",
                  "donut",
                  "pie",
                  "grouped_bar",
                  "stacked_bar",
                  "horizontal_bar",
                  "waterfall",
                  "line_chart",
                  "pareto",
                  "multi_bar_panel",
                  "dashboard_kpi_chart",
                  "dashboard_table_chart",
                  "matrix_2x2",
                  "process_chevron",
                  "timeline",
                  "data_table",
                  "table_insight",
                  "value_chain",
                  "closing",
                  "text"
                ]
              },
              "hierarchy_map": { "type": "array" },
              "reading_order": { "type": "array" },
              "responsive_behavior": { "type": "string" },
              "heading_level": {
                "type": "integer",
                "description": "文档输出时的标题层级，1=章，2=节，3=小节。"
              },
              "document_role": {
                "type": "string",
                "description": "文档章节角色，例如 executive_summary、executive_takeaway、analysis_section、evidence_section、mechanism_section、recommendation_section、appendix_section。format=document 时第一个正文单元必须是 executive_summary。"
              },
              "paragraph_roles": {
                "type": "array",
                "description": "文档章节内段落/bullet 的角色顺序。",
                "items": { "type": "string" }
              },
              "figure_slots": {
                "type": "array",
                "description": "DOCX 图表/表格/引用槽位，含 role、caption、source_note、placement、asset_requirement 等。",
                "items": { "type": "object" }
              }
            }
          },
          "finalized_content": {
            "type": "object",
            "properties": {
              "primary_text": { "type": "string" },
              "supporting_points": { "type": "array", "items": { "type": "string" } },
              "body": { "type": "string" },
              "bullet_groups": {
                "type": "array",
                "description": "文档报告中的多级 bullet 组，建议含 group_title、level、bullets。",
                "items": { "type": "object" }
              },
              "quote_blocks": {
                "type": "array",
                "description": "文档引用块，建议含 quote、attribution、supports_mechanism、evidence_ref。",
                "items": { "type": "object" }
              },
              "formula_lines": {
                "type": "array",
                "description": "文档中需要独立展示的公式或指标定义。",
                "items": { "type": "string" }
              },
              "figure_caption": { "type": "string" },
              "source_note": { "type": "string" },
              "callouts": { "type": "array" },
              "tables": { "type": "array" }
            }
          },
          "visual_object": {
            "type": "object",
            "properties": {
              "visual_type": { "type": "string" },
              "title": { "type": "string" },
              "reader_takeaway": { "type": "string" },
              "data_fields": { "type": "array" },
              "caption": {
                "type": "string",
                "description": "文档图表 caption 或 PPT 图表说明，说明读者应从图中读出什么。"
              },
              "source_note": {
                "type": "string",
                "description": "图表来源、口径、时间窗或样本说明。"
              },
              "chart_spec": {
                "type": "object",
                "description": "图表页/图表章节的结构化渲染参数。按 layout_type/visual_type 填入 grouped_bar、stacked_bar、waterfall、multi_bar_panel、dashboard 等所需字段；不得只写自由文本建议。"
              },
              "document_asset_mode": {
                "type": "string",
                "description": "DOCX 图表资产形态，例如 chart_image、editable_table、quote_callout、appendix_table。"
              },
              "mck_api": {
                "type": "object",
                "description": "面向 mck_ppt renderer 的方法与参数提示，如 method=grouped_bar、args={categories,series,data,...}。后端可据此做确定性渲染或 gate 检查。"
              },
              "asset_requirements": { "type": "array" },
              "limitations": { "type": "array" }
            }
          },
          "source_display": {
            "type": "object",
            "properties": {
              "footer": { "type": "string" },
              "inline_sources": { "type": "array" },
              "confidence_note": { "type": "string" }
            }
          },
          "gap_display": {
            "type": "object",
            "properties": {
              "visible_note": { "type": "string" },
              "hidden_internal_note": { "type": "string" },
              "blocking_level": { "type": "string" }
            }
          },
          "speaker_note_seed": { "type": "string" },
          "question_risk_tags": { "type": "array", "items": { "type": "string" } },
          "quality_status": { "type": "string" }
        }
      }
    },
    "appendix_units": { "type": "array" },
    "style_tokens": {
      "type": "object",
      "properties": {
        "tone": { "type": "string" },
        "density": { "type": "string" },
        "typography": { "type": "object" },
        "color_policy": { "type": "object" },
        "layout_conventions": { "type": "array" }
      }
    },
    "source_policy": { "type": "object" },
    "gap_policy": { "type": "object" },
    "redaction_policy": { "type": "object" },
    "format_decisions": { "type": "array" },
    "open_design_tasks": { "type": "array" },
    "downstream_handoff": {
      "type": "object",
      "properties": {
        "qa_focus_areas": { "type": "array" },
        "speaker_script_focus": { "type": "array" },
        "high_risk_units": { "type": "array" },
        "do_not_overstate": { "type": "array" }
      }
    },
    "quality_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check", "status"],
        "properties": {
          "check": { "type": "string" },
          "status": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "render_result": {
      "type": "object",
      "description": "由渲染后端（renderers/）在 format 提交后回填的实际产物，而非计划态。fidelity 应为 final。",
      "properties": {
        "status": { "type": "string", "enum": ["rendered", "skipped_missing_dep", "error", "no_units"] },
        "format": { "type": "string", "enum": ["ppt", "html", "document"] },
        "fidelity": { "type": "string", "enum": ["draft", "final"] },
        "output_path": { "type": "string" },
        "file_bytes": { "type": "integer" },
        "unit_count": { "type": "integer" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "detail": { "type": "string" }
      }
    }
  }
}
