{
  "schema": "storyline.v1",
  "type": "object",
  "required": ["agent_id", "schema", "topic", "audience", "selected_story_angle", "story_arc", "title_read_test", "pages"],
  "properties": {
    "agent_id": { "const": "storyline_design" },
    "schema": { "const": "storyline.v1" },
    "topic": { "type": "string" },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "report_type": { "type": "string", "enum": ["deep_dive", "quick_sync"] },
    "output_format": { "type": "string", "enum": ["document", "ppt", "html"] },
    "objective": { "type": "string" },
    "selected_story_angle": { "type": "string" },
    "story_angle_options": { "type": "array" },
    "story_arc": { "type": "string" },
    "title_read_test": { "type": "string" },
    "memory_points": { "type": "array", "items": { "type": "string" } },
    "style_guidance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["page_no", "unit_type", "title", "key_question", "role_in_story", "evidence", "expected_evidence_materials", "so_what", "transition", "tag"],
        "properties": {
          "page_no": { "type": "integer" },
          "unit_type": { "type": "string", "enum": ["page", "section", "module"] },
          "title": { "type": "string" },
          "key_question": { "type": "string" },
          "role_in_story": { "type": "string" },
          "evidence_refs": { "type": "array", "items": { "type": "string" } },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_evidence_materials": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["material", "purpose"],
              "properties": {
                "material": { "type": "string" },
                "evidence_ref": { "type": "string" },
                "purpose": { "type": "string" },
                "status": { "type": "string" }
              }
            }
          },
          "so_what": { "type": "string" },
          "transition": { "type": "string" },
          "tag": { "type": "string" }
        }
      }
    },
    "appendix_plan": { "type": "array" },
    "open_questions": { "type": "array" },
    "state_revisions": {
      "type": "object",
      "description": "Optional corrections to upstream global state entries that no longer hold after building the full storyline. Empty by default; populate only when you have reason to revise a prior-stage value.",
      "properties": {
        "target_action": { "type": "string" },
        "executive_summary": { "type": "object" },
        "audience_profile": { "type": "object" },
        "presentation_preferences": { "type": "object" },
        "page_limit": { "type": "integer" }
      }
    }
  }
}
