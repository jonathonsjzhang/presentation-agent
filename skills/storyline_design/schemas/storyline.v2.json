{
  "schema": "storyline.v2",
  "description": "Storyline Design v2：动态 message pyramid、逐单元 leadline spine 与结构化 title-read test。",
  "type": "object",
  "required": [
    "agent_id",
    "schema",
    "topic",
    "audience",
    "objective",
    "message_pyramid",
    "ordering_rationale",
    "closing_intent",
    "title_read_test",
    "pages",
    "appendix_plan",
    "upstream_revision_requests",
    "open_questions"
  ],
  "properties": {
    "agent_id": { "const": "storyline_design" },
    "schema": { "const": "storyline.v2" },
    "topic": { "type": "string" },
    "audience": { "type": "string", "enum": ["board", "exec_office", "strategy_lead", "business_team", "external"] },
    "report_type": { "type": "string", "enum": ["deep_dive", "business_progress", "quick_sync"] },
    "output_format": { "type": "string", "enum": ["document", "ppt", "html"] },
    "objective": { "type": "string" },
    "message_pyramid": {
      "type": "object",
      "required": ["governing_question", "core_answer", "supporting_messages"],
      "properties": {
        "governing_question": { "type": "string", "minLength": 1 },
        "core_answer": { "type": "string", "minLength": 1 },
        "supporting_messages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["message", "relationship_to_core", "source_argument_refs", "page_nos"],
            "properties": {
              "message": { "type": "string", "minLength": 1 },
              "relationship_to_core": {
                "type": "string",
                "description": "自由描述该判断如何支撑、限定、解释或反驳 core answer；不是固定 Story Arc 枚举。"
              },
              "source_argument_refs": {
                "type": "array",
                "items": { "type": "string" }
              },
              "page_nos": {
                "type": "array",
                "items": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "ordering_rationale": {
      "type": "string",
      "description": "解释为什么这些内容必须按当前顺序出现，依据应是论点依赖、受众认知、关键张力或决策成熟度，而非模板名称。"
    },
    "closing_intent": {
      "type": "string",
      "description": "说明结尾要让受众形成什么判断、讨论或行动；不强制 recommendation。"
    },
    "memory_points": {
      "type": "array",
      "items": { "type": "string" }
    },
    "style_guidance": {
      "type": "array",
      "items": { "type": "string" }
    },
    "title_read_test": {
      "type": "object",
      "required": ["title_chain", "passes", "checks", "revision_notes"],
      "properties": {
        "title_chain": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "passes": { "type": "boolean" },
        "checks": {
          "type": "object",
          "required": [
            "completeness",
            "progression",
            "adjacency",
            "necessity",
            "atomicity",
            "supportability",
            "decision_maturity"
          ],
          "properties": {
            "completeness": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "progression": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "adjacency": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "necessity": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "atomicity": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "supportability": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            },
            "decision_maturity": {
              "type": "object",
              "required": ["passes", "issue_pages", "note"],
              "properties": {
                "passes": { "type": "boolean" },
                "issue_pages": { "type": "array", "items": { "type": "integer" } },
                "note": { "type": "string" }
              }
            }
          }
        },
        "revision_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "page_no",
          "unit_type",
          "leadline",
          "title",
          "page_question",
          "points_to_make",
          "role_in_story",
          "evidence_refs",
          "transition_from_previous",
          "transition_to_next",
          "tag"
        ],
        "properties": {
          "page_no": { "type": "integer" },
          "unit_type": { "type": "string", "enum": ["page", "section", "module"] },
          "leadline": { "type": "string", "minLength": 1 },
          "title": {
            "type": "string",
            "minLength": 1,
            "description": "兼容字段，必须与 leadline 完全一致。"
          },
          "page_question": { "type": "string", "minLength": 1 },
          "points_to_make": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "role_in_story": {
            "type": "string",
            "description": "自由描述该单元在当前论证中的职责，不使用固定角色序列。"
          },
          "source_argument_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "transition_from_previous": { "type": "string" },
          "transition_to_next": { "type": "string" },
          "tag": { "type": "string" }
        }
      }
    },
    "appendix_plan": { "type": "array" },
    "upstream_revision_requests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "request_type",
          "source_argument_refs",
          "reason",
          "suggested_change",
          "blocking_level"
        ],
        "properties": {
          "request_type": {
            "type": "string",
            "enum": [
              "overclaim",
              "unsupported_causality",
              "missing_evidence",
              "recommendation_too_specific"
            ]
          },
          "source_argument_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "reason": { "type": "string" },
          "suggested_change": { "type": "string" },
          "blocking_level": {
            "type": "string",
            "enum": ["advisory", "blocking"]
          }
        }
      }
    },
    "open_questions": { "type": "array" },
    "state_revisions": {
      "type": "object",
      "description": "Optional corrections to upstream global state entries that no longer hold after building the full storyline. Empty by default; populate only when you have reason to revise a prior-stage value.",
      "properties": {
        "target_action": { "type": "string" },
        "executive_summary": { "type": "object" },
        "audience_profile": { "type": "object" },
        "presentation_preferences": { "type": "object" },
        "page_limit": { "type": "integer" }
      }
    }
  }
}
