{
  "version": "agent-definition.v2",
  "active_contract_profile": "v0_4",
  "contract_profiles": {
    "v0_4": {
      "status": "active",
      "activation": "default_user_entry",
      "schema_gate_mode": "advisory",
      "activated_at": "2026-07-15",
      "manager_charter_schema": "report_charter.v2",
      "canonical_stages": [
        "analysis",
        "storyline",
        "report",
        "qa_preparation",
        "format"
      ],
      "default_delivery_targets": ["document"],
      "internal_subagents": ["evidence_harvester"],
      "workers": [
        {
          "id": "analysis",
          "name": "分析",
          "stage": 1,
          "skill": "analysis",
          "description": "把证据综合为少量完整发现，并形成 2–3 组可供选择的 Minto 金字塔式候选论点。",
          "previous_agent_id": "manager",
          "next_agent_id": "storyline",
          "input_schema": "report_charter.v2",
          "output_schema": "markdown_artifact.v1",
          "output_contract": {
            "artifact_format": "markdown",
            "artifact_kind": "analysis",
            "canonical_filename": "analysis.md",
            "required_headings": ["核心发现", "竞争性解释与边界", "候选论点组", "核心视觉证据候选", "待验证问题"]
          },
          "memory_dimensions": ["证据完整性", "发现", "替代解释", "So What", "决策张力"],
          "max_revision_rounds": 1,
          "state": {"global_reads": ["audience_profile", "target_action"], "global_writes": [], "generation_memory_dimensions": ["证据完整性", "发现", "替代解释", "So What"]},
          "harness": {"skill_package": "skills/analysis", "runtime_adapter": "markdown_first_skill_runtime", "review_policy": "self_check_plus_file_validation", "connectors": ["doc_reader", "docx_reader", "pdf_reader", "xlsx_reader", "csv_reader"]}
        },
        {
          "id": "storyline",
          "name": "故事线",
          "stage": 2,
          "skill": "storyline",
          "description": "把已确认的 Analysis 论点展开成完整故事线，并基于正文结构写成 250–350 字 bullet 式 Executive Summary。",
          "previous_agent_id": "analysis",
          "next_agent_id": "report",
          "input_schema": "markdown_artifact.v1",
          "output_schema": "markdown_artifact.v1",
          "output_contract": {
            "artifact_format": "markdown",
            "artifact_kind": "storyline",
            "canonical_filename": "storyline.md",
            "required_headings": ["核心答案", "Executive Summary", "故事线", "关键边界", "不进入主线的内容"]
          },
          "memory_dimensions": ["Executive Summary", "Message Pyramid", "论证结构", "章节设计", "证据边界"],
          "max_revision_rounds": 1,
          "state": {"global_reads": ["audience_profile", "target_action", "delivery_budget"], "global_writes": [], "generation_memory_dimensions": ["Executive Summary", "论证结构", "证据边界"]},
          "harness": {"skill_package": "skills/storyline", "runtime_adapter": "markdown_first_skill_runtime", "review_policy": "self_check_plus_file_validation", "connectors": []}
        },
        {
          "id": "report",
          "name": "报告产出",
          "stage": 3,
          "skill": "report",
          "description": "读取完整 Brief、Analysis、Storyline 和 Evidence，写成 canonical Markdown 报告。",
          "previous_agent_id": "storyline",
          "next_agent_id": "qa_preparation",
          "input_schema": "markdown_artifact.v1",
          "output_schema": "markdown_artifact.v1",
          "output_contract": {
            "artifact_format": "markdown",
            "artifact_kind": "report",
            "canonical_filename": "report.md",
            "required_headings": ["Executive Summary"]
          },
          "memory_dimensions": ["完整原稿", "连续写作", "论证完整性", "可追溯性", "Caveat"],
          "max_revision_rounds": 1,
          "state": {"global_reads": ["audience_profile", "target_action", "delivery_budget"], "global_writes": [], "generation_memory_dimensions": ["完整原稿", "论证完整性", "可追溯性", "Caveat"]},
          "harness": {"skill_package": "skills/report", "runtime_adapter": "markdown_first_skill_runtime", "review_policy": "self_check_plus_file_validation", "connectors": []}
        },
        {
          "id": "qa_preparation",
          "name": "Q&A 梳理",
          "stage": 4,
          "skill": "qa_preparation",
          "description": "以听众视角形成独立追问文档，不复制或改写正文。",
          "previous_agent_id": "report",
          "next_agent_id": "format",
          "input_schema": "markdown_artifact.v1",
          "output_schema": "markdown_artifact.v1",
          "output_contract": {
            "artifact_format": "markdown",
            "artifact_kind": "qa",
            "canonical_filename": "qa.md",
            "required_headings": ["听众可能追问的问题"]
          },
          "memory_dimensions": ["挑战问题", "逻辑压力测试", "证据边界", "战略取舍", "受众关注"],
          "max_revision_rounds": 1,
          "state": {"global_reads": ["audience_profile", "target_action"], "global_writes": [], "generation_memory_dimensions": ["挑战问题", "逻辑压力测试", "证据边界", "受众关注"]},
          "harness": {"skill_package": "skills/qa_preparation", "runtime_adapter": "markdown_first_skill_runtime", "review_policy": "self_check_plus_file_validation", "connectors": []}
        },
        {
          "id": "format",
          "name": "可视化",
          "stage": 5,
          "skill": "format",
          "description": "读取 canonical 报告、可选 QA 与 Evidence Assets，选择 renderer 支持的视觉并生成真实交付文件。",
          "previous_agent_id": "qa_preparation",
          "next_agent_id": null,
          "input_schema": "markdown_artifact.v1",
          "output_schema": "format_plan.v1",
          "output_contract": {"artifact_format": "json", "artifact_kind": "format_plan", "canonical_filename": "format_plan.json"},
          "memory_dimensions": ["版式", "视觉层级", "来源映射", "载体适配", "Caveat 保真"],
          "max_revision_rounds": 1,
          "state": {"global_reads": ["audience_profile", "target_action", "delivery_budget"], "global_writes": [], "generation_memory_dimensions": ["版式", "视觉层级", "来源映射", "载体适配"]},
          "harness": {"skill_package": "skills/format", "runtime_adapter": "generic_llm_skill_runtime", "review_policy": "schema_plus_real_render", "connectors": ["docx_writer", "pptx_writer", "html_writer"]}
        }
      ]
    }
  },
  "control_plane": {
    "id": "manager",
    "name": "汇报项目 Manager",
    "skill": "manager",
    "input_schema": "manager_context.v1",
    "output_schema": "manager_decision.v1",
    "memory_dimensions": [
      "任务定义",
      "任务拆解",
      "调度",
      "验收",
      "返工",
      "人审偏好",
      "跨阶段一致性"
    ],
    "human_gates": [
      "plan",
      "final"
    ],
    "worker_execution": "isolated_task_directory",
    "decision_actions": [
      "dispatch",
      "revise",
      "ask_human",
      "complete"
    ]
  },
  "pipeline": {
    "mode": "manager_controlled",
    "stages": [
      "analysis",
      "storyline",
      "report",
      "qa_preparation",
      "format"
    ],
    "human_review_required": true,
    "automatic_backtracking": false,
    "automation_policy": "no_self_triggered_automation; memory update may be assisted after human feedback",
    "default_max_revision_rounds": 2,
    "internal_subagents": [
      "evidence_harvester"
    ]
  },
  "orchestration": {
    "spawn": {
      "adapter": "inline",
      "command": [],
      "invariants": {
        "max_depth": 1
      }
    }
  },
  "state_policy": {
    "global_state_path": "data/global/state.json",
    "learning_event_log_path": "data/learning/events.jsonl",
    "agent_memory_pattern": "data/agents/{agent_id}/memory.json",
    "agent_learning_log_pattern": "data/agents/{agent_id}/learning_log.jsonl",
    "learning_sources": [
      "feedback",
      "success",
      "comparison"
    ],
    "memory_injection": {
      "generation": "retrieve and judge selected memory; inject only the shortest relevant lessons",
      "self_check": "scan all triggers; follow links only after a trigger hit"
    },
    "memory_retrieval_limit": 6,
    "memory_soft_limit": 30,
    "memory_dream_interval": 10
  },
  "loop_steps": [
    {
      "id": "start",
      "owner": "human/script",
      "description": "由人发起，或人选择上游 artifact 后接续"
    },
    {
      "id": "workflow",
      "owner": "skill",
      "description": "读取输入契约、global state、环节 memory，并按 skill SOP 生成 artifact"
    },
    {
      "id": "validation",
      "owner": "runtime",
      "description": "执行文件、Schema 与真实渲染检查"
    },
    {
      "id": "gate",
      "owner": "runtime",
      "description": "确定性错误清除后才进入下一阶段或人工方向确认"
    },
    {
      "id": "human_review",
      "owner": "human",
      "description": "人决定 approve、revise、stop 或手动回到上游重跑"
    }
  ],
  "agents": [
    {
      "id": "evidence_harvester",
      "name": "证据完整盘点",
      "stage": 0,
      "skill": "evidence_harvester",
      "description": "在 Brief 确认前对原始材料做完整、原子化、可追溯的证据盘点，产出可供用户确认且由 Analysis 复用的 Evidence Catalog，不形成战略结论。",
      "previous_agent_id": "manager",
      "next_agent_id": "manager",
      "input_schema": "manager_task.v1",
      "output_schema": "evidence_catalog.v1",
      "input_contract": {
        "required_inputs": [
          "原始材料文件或完整结构化材料",
          "report charter",
          "证据盘点范围"
        ],
        "optional_inputs": [
          "访谈画像",
          "问卷口径",
          "数据字典"
        ],
        "accepted_material_formats": [
          "json",
          "text",
          "md",
          "doc",
          "docx",
          "pdf",
          "xlsx",
          "csv",
          "png",
          "jpg",
          "jpeg"
        ],
        "input_preparation_focus": "完整读取所有 source units，区分文本、表格和图片的检查状态"
      },
      "output_contract": {
        "primary_artifact": "Evidence Catalog",
        "required_handoff_fields": [
          "items",
          "unresolved"
        ],
        "downstream_use": "analysis 基于完整证据目录形成发现、反证、替代解释与置信度"
      },
      "memory_dimensions": [
        "证据完整性",
        "来源追溯",
        "访谈原子性",
        "Caveat",
        "多模态读取"
      ],
      "max_revision_rounds": 2,
      "loop": {
        "trigger": "before_brief_when_raw_materials_exist_without_reusable_catalog",
        "workflow_owner": "skill",
        "validation": "self_check_plus_file_validation",
        "human_review_required": false,
        "p0_revision_policy": "auto_revise_until_clear_or_max_rounds"
      },
      "state": {
        "global_reads": [
          "audience_profile",
          "target_action"
        ],
        "global_writes": [],
        "agent_memory_scope": "evidence_harvester_only",
        "generation_memory_dimensions": [
          "证据完整性",
          "来源追溯",
          "访谈原子性"
        ]
      },
      "harness": {
        "skill_package": "skills/evidence_harvester",
        "runtime_adapter": "generic_llm_skill_runtime",
        "review_policy": "self_check_plus_file_validation",
        "connectors": [
          "doc_reader",
          "docx_reader",
          "pdf_reader",
          "xlsx_reader",
          "csv_reader",
          "json_reader",
          "text_reader",
          "image_reader"
        ],
        "implementation_status": "implemented"
      },
      "optional_features": {}
    }
  ]
}
