          "report charter",
          "证据盘点范围"
        ],
        "optional_inputs": [
          "访谈画像",
          "问卷口径",
          "数据字典"
        ],
        "accepted_material_formats": [
          "json",
          "text",
          "doc",
          "docx",
          "pdf",
          "xlsx",
          "csv",
          "png",
          "jpg",
          "jpeg"
        ],
        "input_preparation_focus": "完整读取所有 source units，区分文本、表格和图片的检查状态"
      },
      "output_contract": {
        "primary_artifact": "Evidence Catalog",
        "required_handoff_fields": [
          "items",
          "unresolved"
        ],
        "downstream_use": "analysis 基于完整证据目录形成发现、反证、替代解释与置信度"
      },
      "memory_dimensions": [
        "证据完整性",
        "来源追溯",
        "访谈原子性",
        "Caveat",
        "多模态读取"
      ],
      "rubrics": [
        "所有 item 必须有真实 source_ref",
        "无法读取或无法定位的内容写入 unresolved",
        "不生成 thesis 或 recommendation"
      ],
      "max_revision_rounds": 2,
      "loop": {
        "trigger": "manager_dispatch_for_deep_dive_or_complex_materials",
        "workflow_owner": "skill",
        "reviewer": "clean_context_review_sub_agent",
        "stop_checker": "schema_and_p0_gate",
        "human_review_required": true,
        "p0_revision_policy": "auto_revise_until_clear_or_max_rounds"
      },
      "state": {
        "global_reads": [
          "audience_profile",
          "target_action"
        ],
        "global_writes": [],
        "agent_memory_scope": "evidence_harvester_only",
        "generation_memory_dimensions": [
          "证据完整性",
          "来源追溯",
          "访谈原子性"
        ]
      },
      "harness": {
        "skill_package": "skills/evidence_harvester",
        "runtime_adapter": "generic_llm_skill_runtime",
        "review_policy": "schema_validation + machine_check + llm_p1",
        "connectors": [
          "doc_reader",
          "docx_reader",
          "pdf_reader",
          "xlsx_reader",
          "csv_reader",
          "image_reader"
        ],
        "implementation_status": "implemented"
      },
      "optional_features": {}
    }
  ]
