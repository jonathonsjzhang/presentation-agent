{
  "version": "context-requirements.v1",
  "contract_profiles": {
    "v0_3": {
      "status": "active",
      "activation": "active_user_default",
      "projection_policy": "namespace_upstream_artifacts_and_inline_only_declared_fields",
      "workers": {
        "analysis": {
          "required_fields": [
            "report_charter",
            "analysis_objective",
            "acceptance_criteria"
          ],
          "conditional_full_fields": [
            "raw_materials",
            "evidence_catalog"
          ],
          "output_schema": "analysis.v1"
        },
        "storyline": {
          "upstream_schema": "analysis.v1",
          "required_fields": [
            "analysis_questions",
            "findings",
            "viewpoint_candidates",
            "decision_tensions",
            "assumptions",
            "data_gaps",
            "discussion_points",
            "open_questions"
          ],
          "excluded_fields": [
            "raw_materials"
          ],
          "output_schema": "storyline.v3"
        },
        "report": {
          "upstream_schema": "storyline.v3",
          "required_fields": [
            "executive_summary",
            "message_pyramid",
            "report_outline",
            "editorial_decisions",
            "upstream_revision_requests",
            "open_questions"
          ],
          "output_schema": "report.v1"
        },
        "format": {
          "upstream_schema": "report.v1",
          "required_fields": [
            "report_metadata",
            "executive_summary",
            "sections",
            "source_registry",
            "caveats_and_limits",
            "recommendations",
            "appendices",
            "format_handoff"
          ],
          "task_fields": [
            "delivery_target"
          ],
          "excluded_fields": [
            "raw_materials",
            "storyline.pages",
            "page_content"
          ],
          "output_schema": "formatted_material.v2"
        },
        "qa_preparation": {
          "upstream_schema": "formatted_material.v2",
          "required_fields": [
            "delivery_target",
            "delivery_units",
            "visual_assets",
            "caveat_preservation",
            "omitted_content_register",
            "quality_checks",
            "artifact_manifest"
          ],
          "output_schema": "qa_pack.v1"
        },
        "speaker_script": {
          "required_fields": [
            "delivery_target",
            "delivery_units",
            "caveat_preservation",
            "quality_checks",
            "top_questions",
            "risk_register",
            "speaker_script_handoff",
            "data_gaps_to_close"
          ],
          "output_schema": "speaker_script.v1"
        }
      }
    }
  },
  "max_inline_chars_per_field": 12000,
  "preview_items": 3,
  "signal_fields": [
    "topic",
    "audience",
    "report_type",
    "output_format",
    "decision_goal",
    "expected_action",
    "core_thesis",
    "global_data_gaps",
    "open_questions"
  ]
}
